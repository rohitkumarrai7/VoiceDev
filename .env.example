# VoiceDev Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ── Speech-to-Text ──────────────────────────────────────────

# Groq API Key (recommended — fastest, free tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (optional — alternative cloud STT)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── Agent LLM (optional — Aider uses its own config by default) ──

# MiniMax API Key (optional — if you want Aider to use MiniMax models)
# MINIMAX_API_KEY=
