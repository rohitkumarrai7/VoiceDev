# VoiceDev Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# Groq API Key (for Groq Whisper STT — free tier available, fastest option)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (optional, for OpenAI Whisper API STT)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
