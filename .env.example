# VoiceDev Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ── Speech-to-Text ──────────────────────────────────────────

# Groq API Key (recommended — fastest, free tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (optional — alternative cloud STT only; comment out if unused)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── Agent LLM: enable ONE block only (comment out the others) ──

# [A] MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=minimax/minimax-m2.7

# [B] OpenRouter / Qwen (comment block A above)
# QWEN3_API_KEY=
# QWEN3_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Or canonical names:
# OPENROUTER_API_KEY=
# AIDER_MODEL=openrouter/qwen/qwen-2.5-coder-32b-instruct:free

# [C] OpenAI for Aider (comment blocks A and B above)
# OPENAI_API_KEY=
# AIDER_MODEL=gpt-4o-mini

# If you must keep multiple agent keys, pick one explicitly:
# VOICEDEV_LLM_PROVIDER=minimax

# Optional overrides (any provider)
# AIDER_API_KEY=
# AIDER_API_BASE=
