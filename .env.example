# VoiceDev Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ── Speech-to-Text ──────────────────────────────────────────

# Groq API Key (recommended — fastest, free tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (optional — STT only when uncommented; do not use for Aider if block C is off)
# OPENAI_API_KEY=

# ── Agent LLM: enable ONE block only (comment out all others) ──

# [A] MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=minimax/minimax-m2.7

# [B] OpenRouter / Qwen (comment block A above)
# QWEN3_API_KEY=
# QWEN3_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Or: OPENROUTER_API_KEY=  and  AIDER_MODEL=openrouter/qwen/qwen-2.5-coder-32b-instruct:free

# [C] OpenAI for Aider (comment blocks A and B above; uncomment OPENAI_API_KEY for STT too if needed)
# OPENAI_API_KEY=
# AIDER_MODEL=gpt-4o-mini

# [D] Claude / Anthropic (comment blocks A–C above)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=anthropic/claude-sonnet-4-20250514

# [E] Gemini (comment blocks A–D above)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini/gemini-2.0-flash

# [F] DeepSeek (comment blocks A–E above)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek/deepseek-chat

# If multiple agent keys are set, pick one:
# VOICEDEV_LLM_PROVIDER=minimax

# Optional overrides (any provider)
# AIDER_API_KEY=
# AIDER_API_BASE=
