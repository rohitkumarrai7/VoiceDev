# VoiceDev Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ── Speech-to-Text ──────────────────────────────────────────

# Groq API Key (recommended — fastest, free tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (optional — alternative cloud STT; can also power Aider)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── Agent LLM (auto-detected — first match: OpenRouter > OpenAI > MiniMax opt-in) ──

# OpenRouter API Key (recommended for Aider — OpenAI-compatible)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Legacy alias for OPENROUTER_API_KEY
# QWEN3_API_KEY=

# Default model when using OpenRouter (override if a model is retired)
AIDER_MODEL=openrouter/qwen/qwen-2.5-coder-32b-instruct:free

# Optional overrides (apply to whichever provider is selected)
# AIDER_API_KEY=
# AIDER_API_BASE=

# MiniMax API Key (optional — only used when explicitly enabled below)
# MINIMAX_API_KEY=
# VOICEDEV_USE_MINIMAX=true

# ── Cloud ────────────────────────────────────────────────────

#